{
  "name": "@sagentong/storage",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "storage:start": "docker compose up -d",
    "storage:watch": "docker compose up",
    "storage:stop": "docker compose stop",
    "storage:down": "docker compose down"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.826.0",
    "@aws-sdk/lib-storage": "^3.826.0",
    "@sagentong/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@sagentong/config": "workspace:*",
    "@types/node": "^22.13.14",
    "typescript": "catalog:"
  }
}
